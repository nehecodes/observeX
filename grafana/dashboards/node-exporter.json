{
  "uid": "node-exporter",
  "title": "Node Exporter — System Metrics",
  "description": "CPU (total + per-core), memory, disk I/O, network I/O, and system load averages",
  "tags": ["observeX", "infrastructure", "node-exporter"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(node_uname_info, instance)",
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "CPU",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU Usage — Total (%)",
      "description": "Average CPU utilisation across all cores",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\", instance=\"$instance\"}[5m])) * 100)",
          "legendFormat": "CPU total"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "CPU Usage — Per Core (%)",
      "description": "Per-CPU utilisation breakdown",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "expr": "100 - (rate(node_cpu_seconds_total{mode=\"idle\", instance=\"$instance\"}[5m]) * 100)",
          "legendFormat": "CPU {{cpu}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "CPU Usage Now",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\", instance=\"$instance\"}[5m])) * 100)",
          "legendFormat": "CPU %"
        }
      ]
    },
    {
      "id": 5,
      "type": "row",
      "title": "Memory",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Memory — Used / Cached / Available",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{instance=\"$instance\"} - node_memory_MemAvailable_bytes{instance=\"$instance\"}",
          "legendFormat": "Used"
        },
        {
          "expr": "node_memory_Cached_bytes{instance=\"$instance\"}",
          "legendFormat": "Cached"
        },
        {
          "expr": "node_memory_MemAvailable_bytes{instance=\"$instance\"}",
          "legendFormat": "Available"
        }
      ]
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "Memory Usage %",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes{instance=\"$instance\"} - node_memory_MemAvailable_bytes{instance=\"$instance\"}) / node_memory_MemTotal_bytes{instance=\"$instance\"} * 100",
          "legendFormat": "Memory %"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Total RAM",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{instance=\"$instance\"}",
          "legendFormat": "Total RAM"
        }
      ]
    },
    {
      "id": 9,
      "type": "row",
      "title": "Disk I/O",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Disk I/O — Read / Write (bytes/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "sum by(instance) (rate(node_disk_read_bytes_total{instance=\"$instance\"}[5m]))",
          "legendFormat": "Read"
        },
        {
          "expr": "sum by(instance) (rate(node_disk_written_bytes_total{instance=\"$instance\"}[5m]))",
          "legendFormat": "Write"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Disk Usage — Root Filesystem (%)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "(node_filesystem_size_bytes{instance=\"$instance\", mountpoint=\"/\", fstype!~\"tmpfs|overlay\"} - node_filesystem_free_bytes{instance=\"$instance\", mountpoint=\"/\", fstype!~\"tmpfs|overlay\"}) / node_filesystem_size_bytes{instance=\"$instance\", mountpoint=\"/\", fstype!~\"tmpfs|overlay\"} * 100",
          "legendFormat": "Disk used %"
        }
      ]
    },
    {
      "id": 12,
      "type": "row",
      "title": "Network I/O",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Network — Receive / Transmit (bytes/s)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "expr": "sum by(instance) (rate(node_network_receive_bytes_total{instance=\"$instance\", device!~\"lo|veth.*\"}[5m]))",
          "legendFormat": "RX"
        },
        {
          "expr": "sum by(instance) (rate(node_network_transmit_bytes_total{instance=\"$instance\", device!~\"lo|veth.*\"}[5m]))",
          "legendFormat": "TX"
        }
      ]
    },
    {
      "id": 14,
      "type": "row",
      "title": "System Load",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "System Load Average (1m / 5m / 15m)",
      "description": "Load average vs number of CPU cores. Values above the core count indicate saturation.",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "node_load1{instance=\"$instance\"}",
          "legendFormat": "Load 1m"
        },
        {
          "expr": "node_load5{instance=\"$instance\"}",
          "legendFormat": "Load 5m"
        },
        {
          "expr": "node_load15{instance=\"$instance\"}",
          "legendFormat": "Load 15m"
        },
        {
          "expr": "count(node_cpu_seconds_total{instance=\"$instance\", mode=\"idle\"})",
          "legendFormat": "CPU cores"
        }
      ]
    },
    {
      "id": 16,
      "type": "stat",
      "title": "CPU Cores",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "count(node_cpu_seconds_total{instance=\"$instance\", mode=\"idle\"})",
          "legendFormat": "Cores"
        }
      ]
    },
    {
      "id": 17,
      "type": "stat",
      "title": "System Uptime",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "node_time_seconds{instance=\"$instance\"} - node_boot_time_seconds{instance=\"$instance\"}",
          "legendFormat": "Uptime"
        }
      ]
    }
  ]
}
