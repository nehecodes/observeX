{
  "uid": "unified-observability",
  "title": "Unified Observability",
  "description": "Metrics, Logs, and Traces in one view. Click metric spikes to drill down into Loki logs, then click trace IDs to open in Tempo.",
  "tags": ["unified", "correlation", "traces", "logs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "annotations": {
    "list": [
      {
        "name": "Deployments",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "changes(github_actions_deployments_total{environment=\"production\"}[2m]) > 0",
        "step": "60s",
        "titleFormat": "Deployment",
        "textFormat": "Production deployment",
        "iconColor": "blue",
        "enable": true
      }
    ]
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_requests_total, job)",
        "refresh": 2,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Golden Signals — Entry Point for Investigation",
      "description": "Click any panel to navigate to correlated Loki logs for the selected time window.",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 2,
      "title": "Error Rate",
      "description": "Spike here? Click 'Explore in Loki' to see correlated error logs, then follow trace IDs to Tempo.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\", job=~\"$service\"}[5m]))",
          "legendFormat": "Error rate (5xx/s)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{job=~\"$service\"}[5m]))",
          "legendFormat": "Total request rate (/s)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Error rate (5xx/s)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "links": [
        {
          "title": "Explore errors in Loki",
          "url": "/explore?left={\"datasource\":\"loki\",\"queries\":[{\"expr\":\"{service_name=\\\"$service\\\"} |= \\\"error\\\"\",\"refId\":\"A\"}],\"range\":{\"from\":\"${__from}\",\"to\":\"${__to}\"}}",
          "targetBlank": true
        }
      ]
    },
    {
      "id": 3,
      "title": "P99 Latency",
      "description": "Latency spike? Drill down to Loki slow-request logs, then find the causing trace in Tempo.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=~\"$service\"}[5m])) by (le))",
          "legendFormat": "p99 latency",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=~\"$service\"}[5m])) by (le))",
          "legendFormat": "p95 latency",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=~\"$service\"}[5m])) by (le))",
          "legendFormat": "p50 latency",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red",    "value": 0.5 }
            ]
          }
        }
      },
      "links": [
        {
          "title": "Explore slow requests in Loki",
          "url": "/explore?left={\"datasource\":\"loki\",\"queries\":[{\"expr\":\"{service_name=\\\"$service\\\"} |= \\\"slow\\\" or |= \\\"timeout\\\"\",\"refId\":\"A\"}],\"range\":{\"from\":\"${__from}\",\"to\":\"${__to}\"}}",
          "targetBlank": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Request Volume",
      "description": "Traffic — requests per second by service.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=~\"$service\"}[5m])) by (job)",
          "legendFormat": "{{ job }} RPS",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 5,
      "title": "Error Ratio",
      "description": "Percentage of requests returning 5xx.",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "job:http_error_ratio:rate5m * 100",
          "legendFormat": "{{ job }} error %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    },
    {
      "id": 6,
      "title": "SLO Burn Rate",
      "description": "Real-time burn rate. Threshold lines at 5x (slow burn) and 14.4x (fast burn).",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "job:http_error_ratio:rate1h / 0.01",
          "legendFormat": "Burn Rate (1h)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red",    "value": 14.4 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Correlated Logs — Step 2 of Drill-Down",
      "description": "Loki logs filtered to the selected service and time window. Look for traceID= fields — click them to open in Tempo.",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 }
    },
    {
      "id": 11,
      "title": "Application Logs",
      "description": "Logs from the selected service. Error and warning lines are highlighted. Click any traceID= value to jump to Tempo.",
      "type": "logs",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=~\"$service\"} |= \"\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 12,
      "title": "Error Logs Only",
      "description": "Only lines containing 'error', 'ERROR', or 'exception'. Trace IDs here point directly to failing request traces.",
      "type": "logs",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=~\"$service\"} |~ \"(?i)(error|exception|fatal|panic)\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Traces — Step 3 of Drill-Down",
      "description": "Search for traces by service and time window. Or click a traceID link from the Logs panels above.",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 1 }
    },
    {
      "id": 21,
      "title": "Recent Traces",
      "description": "Traces from Tempo for the selected service. Click any Trace ID to open the full span waterfall in Tempo.",
      "type": "table",
      "gridPos": { "x": 0, "y": 29, "w": 24, "h": 8 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "options": {
        "sortBy": [{ "displayName": "Start time", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "traceID" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open in Tempo",
                    "url": "/explore?left={\"datasource\":\"tempo\",\"queries\":[{\"refId\":\"A\",\"queryType\":\"traceId\",\"query\":\"${__value.raw}\"}],\"range\":{\"from\":\"now-1h\",\"to\":\"now\"}}",
                    "targetBlank": true
                  }
                ]
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\"}",
          "refId": "A",
          "limit": 20,
          "tableType": "traces"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Service Map",
      "gridPos": { "x": 0, "y": 37, "w": 24, "h": 1 }
    },
    {
      "id": 31,
      "title": "Service Dependency Map",
      "description": "Node graph showing request flow between services. Node size = request rate. Edge colour = error rate.",
      "type": "nodeGraph",
      "gridPos": { "x": 0, "y": 38, "w": 24, "h": 10 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "queryType": "serviceMap",
          "refId": "A"
        }
      ]
    }
  ]
}
