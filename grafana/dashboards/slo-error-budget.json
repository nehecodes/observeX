{
  "uid": "slo-error-budget",
  "title": "SLO & Error Budget",
  "description": "SLI vs SLO gauges, error budget remaining, burn rate time series, and SLO compliance history.",
  "tags": ["slo", "error-budget", "reliability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "SLI vs SLO — Current Status",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 2,
      "title": "Availability SLI",
      "description": "Current 24h probe success rate. SLO target: 99.5%",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg_over_time(probe_success{job=\"blackbox-http\"}[24h]) * 100",
          "legendFormat": "Availability %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 95,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green",  "value": 99.5 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 3,
      "title": "Error Rate SLI",
      "description": "Current 5m request success rate. SLO target: 99%",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(1 - job:http_error_ratio:rate5m) * 100",
          "legendFormat": "Success Rate %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 95,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 98 },
              { "color": "green",  "value": 99 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 4,
      "title": "Latency SLI",
      "description": "% of requests completing under 500ms. SLO target: 95%",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_bucket{le=\"0.5\"}[5m])) / sum(rate(http_request_duration_seconds_count[5m])) * 100",
          "legendFormat": "< 500ms %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 80,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green",  "value": 95 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 5,
      "title": "SLO Compliance (7d)",
      "description": "Are all SLOs currently being met?",
      "type": "stat",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg_over_time(probe_success{job=\"blackbox-http\"}[7d]) * 100",
          "legendFormat": "Availability 7d",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 99.5 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value_and_name" }
    },
    {
      "id": 6,
      "title": "SLO Compliance (30d)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 4, "w": 6, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg_over_time(probe_success{job=\"blackbox-http\"}[30d]) * 100",
          "legendFormat": "Availability 30d",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 99.5 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value_and_name" }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Error Budget Remaining",
      "gridPos": { "x": 0, "y": 7, "w": 24, "h": 1 }
    },
    {
      "id": 11,
      "title": "Availability Error Budget Remaining (%)",
      "description": "100% = full budget intact. 0% = SLO breached. Budget = 216 minutes per 30 days.",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "clamp_min((1 - (1 - avg_over_time(probe_success{job=\"blackbox-http\"}[30d])) / 0.005) * 100, 0)",
          "legendFormat": "Availability Budget %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "green",  "value": 50 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "id": 12,
      "title": "Error Rate Budget Remaining (%)",
      "description": "Budget = 432 minutes of error-rate violations per 30 days.",
      "type": "bargauge",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "clamp_min((1 - job:http_error_ratio:rate3d / 0.01) * 100, 0)",
          "legendFormat": "Error Rate Budget %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "green",  "value": 50 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "id": 13,
      "title": "Availability Budget Remaining (minutes)",
      "description": "Absolute minutes of downtime allowance left this month (out of 216).",
      "type": "stat",
      "gridPos": { "x": 16, "y": 8, "w": 4, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "clamp_min(216 - ((1 - avg_over_time(probe_success{job=\"blackbox-http\"}[30d])) * 43200), 0)",
          "legendFormat": "Budget (min)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 22 },
              { "color": "green",  "value": 108 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 14,
      "title": "Error Rate Budget Remaining (minutes)",
      "description": "Absolute minutes of error-rate violations left this month (out of 432).",
      "type": "stat",
      "gridPos": { "x": 20, "y": 8, "w": 4, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "clamp_min(432 - (job:http_error_ratio:rate3d * 43200), 0)",
          "legendFormat": "Budget (min)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 43 },
              { "color": "green",  "value": 216 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Burn Rate",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 }
    },
    {
      "id": 21,
      "title": "Error Rate Burn Rate",
      "description": "1.0 = consuming budget at exactly the 30-day rate (sustainable). 14.4 = Fast Burn threshold. 5.0 = Slow Burn threshold.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "job:http_error_ratio:rate1h / 0.01",
          "legendFormat": "Burn Rate (1h window)",
          "refId": "A"
        },
        {
          "expr": "job:http_error_ratio:rate6h / 0.01",
          "legendFormat": "Burn Rate (6h window)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red",    "value": 14.4 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Burn Rate (1h window)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Burn Rate (6h window)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "SLO Compliance History",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 1 }
    },
    {
      "id": 31,
      "title": "Availability SLO History (30 days)",
      "description": "Probe success rate over time vs 99.5% SLO target line.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 23, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg_over_time(probe_success{job=\"blackbox-http\"}[1h]) * 100",
          "legendFormat": "Availability (1h avg)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 95,
          "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 99.5 }
            ]
          }
        }
      }
    },
    {
      "id": 32,
      "title": "Error Rate SLO History (30 days)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 23, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(1 - job:http_error_ratio:rate1h) * 100",
          "legendFormat": "Success Rate (1h avg)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 95,
          "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    }
  ]
}
